<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.layout.HBox?>
<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.edu.ifg.luziania.p3.mvc.controller.EditarPerfilController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="Editar Perfil">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <ImageView fx:id="imgPerfil" fitHeight="150.0" fitWidth="150.0" onMouseClicked="#alterarFoto" pickOnBounds="true" preserveRatio="true" style="-fx-cursor: hand;" />
    <Label text="Clique na imagem para alterar a foto" textFill="#888888" />

    <VBox spacing="5.0" maxWidth="300.0">
        <Label text="Nome de Usuário:" />
        <TextField fx:id="txtUsername" promptText="Seu novo nome de usuário" />
    </VBox>

    <VBox spacing="5.0" maxWidth="300.0">
        <Label text="Email:" />
        <TextField fx:id="txtEmail" promptText="Seu novo email" />
    </VBox>

    <VBox spacing="5.0" maxWidth="300.0">
        <Label text="Senha Antiga (Obrigatório para trocar senha):" />
        <PasswordField fx:id="txtSenhaAntiga" promptText="Senha atual" />
    </VBox>

    <VBox spacing="5.0" maxWidth="300.0">
        <Label text="Nova Senha:" />
        <PasswordField fx:id="txtNovaSenha" promptText="Nova senha" />
    </VBox>

    <Label fx:id="lblMensagem" text="" textFill="RED" wrapText="true" maxWidth="300.0" />

    <HBox alignment="CENTER" spacing="10.0" maxWidth="300.0">
        <Button mnemonicParsing="false" onAction="#voltar" text="Voltar" prefWidth="145.0" style="-fx-background-color: #757575; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <Button mnemonicParsing="false" onAction="#salvarAlteracoes" text="Salvar Alterações" prefWidth="145.0" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </HBox>
</VBox>