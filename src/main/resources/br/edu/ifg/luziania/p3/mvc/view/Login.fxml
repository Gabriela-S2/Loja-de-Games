<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane prefHeight="400.0" prefWidth="650.0" style="-fx-background-color: black;"
           stylesheets="@style.css"
           xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="br.edu.ifg.luziania.p3.mvc.controller.LoginController">
   <children>
      <VBox alignment="CENTER" maxWidth="350.0" spacing="15.0"
            style="-fx-background-color: #171a21; -fx-padding: 30; -fx-background-radius: 10;">
         <children>
            <ImageView fitHeight="100.0" fitWidth="100.0" preserveRatio="true">
               <image><Image url="@img/logo-steam.png" /></image>
            </ImageView>

            <Label text="INICIAR SESSÃO" textFill="WHITE">
               <font><Font name="System Bold" size="18.0" /></font>
            </Label>

            <!-- Label de erro/feedback -->
            <Label fx:id="lblMensagem" maxWidth="290.0" style="-fx-text-fill: #d9534f;" wrapText="true" />

            <Pane prefHeight="75.0" prefWidth="290.0">
               <children>
                  <TextField fx:id="txtUsuario" prefHeight="31.0" prefWidth="290.0"
                             promptText="Nome de usuário ou e-mail"
                             style="-fx-background-color: #32353c; -fx-text-fill: white;" />
                  <PasswordField fx:id="txtSenha" layoutY="44.0" prefHeight="31.0" prefWidth="290.0"
                                 promptText="Senha"
                                 style="-fx-background-color: #32353c; -fx-text-fill: white;" />
               </children>
            </Pane>

            <Button fx:id="btnLogin" maxWidth="Infinity" mnemonicParsing="false"
                    onAction="#realizarLogin" prefHeight="38.0"
                    style="-fx-background-color: #4c6b22; -fx-font-weight: bold;"
                    text="Entrar" textFill="WHITE">
               <cursor><Cursor fx:constant="HAND" /></cursor>
               <font><Font size="16.0" /></font>
            </Button>

            <Hyperlink onAction="#irParaTrocarSenha" text="Esqueci minha senha"
                       textFill="#66c0f4" underline="true" />

            <HBox alignment="CENTER" spacing="5.0">
               <children>
                  <Label text="Ainda não tem uma conta?" textFill="WHITE">
                     <font><Font size="13.0" /></font>
                  </Label>
                  <Hyperlink onAction="#irParaCadastro" text="Crie uma conta"
                             textFill="#66c0f4" underline="true">
                     <font><Font size="13.0" /></font>
                  </Hyperlink>
               </children>
            </HBox>
         </children>
         <effect><DropShadow color="#000000bb" radius="15" /></effect>
      </VBox>
   </children>
</StackPane>